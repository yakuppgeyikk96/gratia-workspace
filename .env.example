# Environment
# Production is opt-in. Anything other than "production" resolves to the local
# database, so forgetting this variable can never write to Supabase.
NODE_ENV=development

# PostgreSQL
# Local dev: docker-compose sets DATABASE_URL_LOCAL for the API container
# (postgres:5432). You only need to fill this in for production.
DATABASE_URL_PRODUCTION=

# Auth
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_SECRET_KEY=your-encryption-key

# Email (Resend)
# RESEND_API_KEY is required — the API refuses to boot without it.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Gratia <onboarding@resend.dev>

# Redis
# Only used in production; docker-compose points the API at the local redis service.
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
FRONTEND_URL=http://localhost:3001
CACHE_SECRET_KEY=any-random-string
