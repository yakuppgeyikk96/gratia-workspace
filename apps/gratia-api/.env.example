# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# PostgreSQL — matches the postgres service in docker-compose.yml.
# Local dev: from host, use localhost:5432. Inside docker network, the API
# container overrides this to postgres:5432 via docker-compose env.
DATABASE_URL_LOCAL=postgresql://gratia:gratia@localhost:5432/gratia_dev
# Cloud Run injects the real production URL via Secret Manager; leave blank
# locally unless you have a specific reason to hit prod from your machine.
DATABASE_URL_PRODUCTION=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Email Configuration (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Gratia <onboarding@resend.dev>

# Observability — gates GET/POST /api/metrics
# Dev: leave empty to allow open access (NODE_ENV=development only).
# Prod: set a shared secret; clients must send `Authorization: Bearer <token>`.
METRICS_TOKEN=
