# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
MONGO_URI=mongodb://localhost:27017/gratia-api

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Email Configuration (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Gratia <onboarding@resend.dev>

# Observability — gates GET/POST /api/metrics
# Dev: leave empty to allow open access (NODE_ENV=development only).
# Prod: set a shared secret; clients must send `Authorization: Bearer <token>`.
METRICS_TOKEN=
